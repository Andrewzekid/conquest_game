<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Project Conquest - 2.5D Map</title>
    <style>
        body { margin: 0; overflow: hidden; background-color: #1a1a1a; font-family: sans-serif; }
        #ui {
            position: absolute;
            top: 20px;
            left: 20px;
            color: white;
            background: rgba(0,0,0,0.7);
            padding: 15px;
            border-radius: 8px;
            pointer-events: none;
        }
        canvas { display: block; }
    </style>
</head>
<body>
    <div id="ui">
        <h1>Project Conquest</h1>
        <p>2.5D Isometric Map Prototype</p>
        <div id="info">Hover over a tile</div>
    </div>

    <script type="importmap">
        {
            "imports": {
                "three": "https://unpkg.com/three@0.160.0/build,three.module.js",
                "three/addons/": "https://unpkg.com/three@0.160.0/examples/jsm/"
            }
        }
    </script>

    <script type="module">
        import * as THREE from 'three';
        import { OrbitControls } from 'three/addons/controls/OrbitControls.js';

        // --- Configuration ---
        const GRID_SIZE = 20;
        const TILE_SIZE = 1;
        const TERRAIN = {
            PLAINS: { color: 0x7cfc00, name: 'Plains', resource: 'Food' },
            FOREST: { color: 0x228b22, name: 'Forest', resource: 'Wood' },
            MOUNTAIN: { color: 0x808080, name: 'Mountain', resource: 'Iron' },
            CITY: { color: 0xffd700, name: 'City', resource: 'Gold' }
        };

        // --- Setup ---
        const scene = new THREE.Scene();
        scene.background = new THREE.Color(0x222222);

        // Isometric Camera setup
        const aspect = window.innerWidth / window.innerHeight;
        const d = 10;
        const camera = new THREE.OrthographicCamera(-d * aspect, d * aspect, d, -d, 1, 1000);

        // Position camera for isometric view (45 deg rotation)
        camera.position.set(20, 20, 20);
        camera.lookAt(0, 0, 0);

        const renderer = new THREE.WebGLRenderer({ antialias: true });
        renderer.setSize(window.innerWidth, window.innerHeight);
        document.body.appendChild(renderer.domElement);

        const controls = new OrbitControls(camera, renderer.domElement);
        controls.enableRotate = false; // Keep isometric perspective fixed
        controls.enablePan = true;
        controls.enableZoom = true;

        const light = new THREE.DirectionalLight(0xffffff, 1);
        light.position.set(10, 20, 10);
        scene.add(light);
        scene.add(new THREE.AmbientLight(0x404040));

        // --- Map Generation ---
        const mapGroup = new THREE.Group();
        scene.add(mapGroup);

        const tiles = [];
        const geometry = new THREE.BoxGeometry(TILE_SIZE * 0.95, 0.2, TILE_SIZE * 0.95);

        for (let x = 0; x < GRID_SIZE; x++) {
            for (let z = 0; z < GRID_SIZE; z++) {
                // Randomly assign terrain
                const rand = Math.random();
                let type;
                if (rand < 0.6) type = TERRAIN.PLAINS;
                else if (rand < 0.8) type = TERRAIN.FOREST;
                else if (rand < 0.95) type = TERRAIN.MOUNTAIN;
                else type = TERRAIN.CITY;

                const material = new THREE.MeshPhongMaterial({ color: type.color });
                const tile = new THREE.Mesh(geometry, material);

                // Offset to center the grid
                tile.position.set(
                    x - GRID_SIZE / 2,
                    type === TERRAIN.MOUNTAIN ? 0.5 : (type === TERRAIN.CITY ? 0.8 : 0),
                    z - GRID_SIZE / 2
                );

                tile.userData = { ...type, x, z };
                mapGroup.add(tile);
                tiles.push(tile);
            }
        }

        // --- Interaction ---
        const raycaster = new THREE.Raycaster();
        const mouse = new THREE.Vector2();
        const infoEl = document.getElementById('info');

        window.addEventListener('mousemove', (event) => {
            mouse.x = (event.clientX / window.innerWidth) * 2 - 1;
            mouse.y = -(event.clientY / window.innerHeight) * 2 + 1;

            raycaster.setFromCamera(mouse, camera);
            const intersects = raycaster.intersectObjects(tiles);

            if (intersects.length > 0) {
                const data = intersects[0].object.userData;
                infoEl.innerText = `${data.name} [${data.x}, ${data.z}] - Produces: ${data.resource}`;
            } else {
                infoEl.innerText = 'Hover over a tile';
            }
        });

        // --- Render Loop ---
        function animate() {
            requestAnimationFrame(animate);
            controls.update();
            renderer.render(scene, camera);
        }

        window.addEventListener('resize', () => {
            const aspect = window.innerWidth / window.innerHeight;
            camera.left = -d * aspect;
            camera.right = d * aspect;
            camera.top = d;
            camera.bottom = -d;
            camera.updateProjectionMatrix();
            renderer.setSize(window.innerWidth, window.innerHeight);
        });

        animate();
    </script>
</body>
</html>
